# Swift Ride — environment variables (PLACEHOLDERS ONLY — never commit real values)
# Copy to .env.local for development, and set the same keys in your host (e.g. Vercel) for production.

# ── Database (server-only) ──────────────────────────────────────────────
# MongoDB Atlas connection string. Use a PRODUCTION cluster/database for prod.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/swiftride?retryWrites=true&w=majority"

# ── Auth (server-only) ──────────────────────────────────────────────────
# >=32 random chars. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="<32+_char_random_secret>"

# ── App URL ─────────────────────────────────────────────────────────────
# Used for password-reset links and Stripe redirects. MUST be your real prod URL in production.
NEXT_PUBLIC_APP_URL="https://your-production-domain.com"

# ── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_or_test_xxx"               # server-only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_or_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"                      # server-only (from Stripe webhook endpoint)

# ── Google Maps ─────────────────────────────────────────────────────────
# Browser key: restrict by HTTP referrer to your prod domain; enable Maps JavaScript + Places.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="<browser_key>"
# Server key: server-only. Restrict by IP (or none) + enable Routes API + Geocoding API. NEVER expose to the browser.
GOOGLE_MAPS_SERVER_API_KEY="<server_key>"

# ── Fare configuration (server-only, optional — sensible defaults in code) ─
MAPS_PRICE_BASE_FARE="100"
MAPS_PRICE_PER_KM="60"
MAPS_PRICE_PER_MINUTE="5"
MAPS_PRICE_MINIMUM_FARE="300"

# ── Email (Gmail SMTP, server-only) ─────────────────────────────────────
# Used for email verification + password-reset emails.
# Without these, emails are NOT sent in production (in dev they log to the console).
# Steps:
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to https://myaccount.google.com/apppasswords and generate an App Password.
#   3. Paste it (16 chars, no spaces) as GMAIL_APP_PASSWORD below.
GMAIL_USER="your-gmail-address@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"   # 16-char app password from Google

# ── NOT used by this project (documented to avoid confusion) ─────────────
# This app uses MongoDB (MONGODB_URI), not SQL — there is no DATABASE_URL.
# It uses NEXT_PUBLIC_APP_URL, not a separate APP_URL.
# It sends email via Gmail SMTP (nodemailer) — RESEND_API_KEY / EMAIL_FROM /
# SENDGRID_API_KEY / SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS are not required.
